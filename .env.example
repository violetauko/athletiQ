# Copy to `.env.local` and fill in values. Never commit real secrets.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- PayPal (required for PayPal: donations, athlete registration fee, marketplace) ---
# Sandbox: https://developer.paypal.com/dashboard/applications/sandbox
# Live: use production credentials when deploying.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Payments (shared) ---
# Athlete entry fee in KES (Stripe, M-Pesa, Stanbic, PesaPal — not PayPal).
NEXT_PUBLIC_ENTRY_FEE_AMOUNT=1000

# PayPal-specific amounts are defined in code (lib/paypal-pricing.ts):
# registration fee KES 1200; marketplace orders add KES 500 on top of cart total.

# Copy to `.env.local` and fill in values. Never commit real secrets.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- PayPal (required for PayPal: donations, athlete registration fee, marketplace) ---
# Sandbox: https://developer.paypal.com/dashboard/applications/sandbox
# Live: use production credentials when deploying.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Payments (shared) ---
# Athlete entry fee in KES (Stripe, M-Pesa, Stanbic, PesaPal — not PayPal).
NEXT_PUBLIC_ENTRY_FEE_AMOUNT=1000

# PayPal-specific amounts are defined in code (lib/paypal-pricing.ts):
# registration fee KES 1200; marketplace orders add KES 500 on top of cart total.

# --- Wise (bank transfer instructions; server-only except where noted) ---
# Shown to customers at checkout / paywall. At least recipient name + IBAN or account number required.
WISE_RECIPIENT_NAME=Athletec
WISE_IBAN=
# If no IBAN (some countries), set account number instead of or in addition to IBAN:
WISE_ACCOUNT_NUMBER=
WISE_BIC=
WISE_BANK_NAME=
# Optional extra lines (sort code, address, “include reference in payment note”, etc.)
WISE_PAYMENT_NOTES=Payment to Athletec

# --- Partnerize (affiliate attribution for Wise confirmations) ---
# When visitors land with ?camref=... (or clickref, pubref, cref), we store it in a cookie and copy it onto Wise Payment rows.
# Optional cookie name override (default: athq_affiliate_ref).
# PARTNERIZE_AFFILIATE_COOKIE_NAME=athq_affiliate_ref
#
# When an admin confirms a Wise payment, we GET this URL if set (placeholders: {camref}, {reference}, {value}, {currency}).
# {value} = Payment.amount (whole units, e.g. KES). {reference} = payment id. Skip ping if payment has no stored click ref.
# PARTNERIZE_CONVERSION_URL_TEMPLATE=https://your-partnerize-or-middleware-endpoint.example/track?camref={camref}&order={reference}&amt={value}&ccy={currency}
